function check26() { check(26, 6.28, 9); }

// ОБЩАЯ ФУНКЦИЯ ПРОВЕРКИ
function check(num, correct, points) {
    var ans = parseFloat(document.getElementById('ans' + num).value);
    var res = document.getElementById('res' + num);
    var sol = document.getElementById('sol' + num);
    
    if (isNaN(ans)) {
        alert('Введите ответ!');
        return;
    }
    
    var tolerance = 0.01;
    if (num == 23) tolerance = 1; // Для больших чисел
    
    if (Math.abs(ans - correct) < tolerance) {
        res.innerHTML = 'ПРАВИЛЬНО! +' + points + ' балл(а)';
        res.style.background = '#d4edda';
        res.style.display = 'block';
        sol.style.display = 'none';
        total = total + points;
    } else {
        res.innerHTML = 'НЕПРАВИЛЬНО. Правильный ответ: ' + correct;
        res.style.background = '#f8d7da';
        res.style.display = 'block';
        sol.style.display = 'block';
    }
    
    document.getElementById('totalScore').innerHTML = 'ИТОГО: ' + total + ' / 100 баллов';
}

// СБРОС ВСЕХ ЗАДАНИЙ
function resetAll() {
    total = 0;
    document.getElementById('totalScore').innerHTML = 'ИТОГО: 0 / 100 баллов';
    
    for (var i = 1; i <= 26; i++) {
        var res = document.getElementById('res' + i);
        var sol = document.getElementById('sol' + i);
        var inp = document.getElementById('ans' + i);
        if (res) { res.style.display = 'none'; }
        if (sol) { sol.style.display = 'none'; }
        if (inp) { inp.value = ''; }
    }
}

// ПОКАЗАТЬ ВСЕ РЕШЕНИЯ
function showAll() {
    for (var i = 1; i <= 26; i++) {
        var sol = document.getElementById('sol' + i);
        if (sol) { sol.style.display = 'block'; }
    }
}
</script>

