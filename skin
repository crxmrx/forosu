<html>
<head>
<meta http-equiv="Content-Type" content="text/html; charset=windows-1251">
<title>Инженерный калькулятор для ЕГЭ</title>
<style>
body { font-family: Arial; background: #1e3c5c; }
.calc { width: 450px; margin: 20px auto; background: #e6f0fa; padding: 20px; border-radius: 10px; border: 2px solid #2c3e50; }
.display { background: white; padding: 15px; margin-bottom: 15px; border: 1px solid #2c3e50; border-radius: 5px; }
#result { width: 100%; font-size: 28px; border: none; text-align: right; outline: none; font-family: Arial; background: white; }
.buttons { display: grid; grid-template-columns: repeat(6, 1fr); gap: 5px; }
button { padding: 15px; font-size: 16px; border: 1px solid #2c3e50; border-radius: 5px; background: #f0f8ff; cursor: pointer; }
button:hover { background: #d4e4f5; }
.func { background: #c0d4e8; }
.num { background: white; }
.op { background: #d4e4f5; }
.clear { background: #ffb6b6; }
.equals { background: #ffd966; grid-column: span 2; }
.memory { background: #2c3e50; color: white; padding: 10px; border-radius: 5px; margin-bottom: 10px; text-align: center; }
.memory button { padding: 8px; margin: 0 2px; background: #e6f0fa; }
</style>
</head>
<body>

<div class="calc">
<center><h2>ИНЖЕНЕРНЫЙ КАЛЬКУЛЯТОР</h2></center>

<div class="memory">
<span id="memDisplay">Память: 0</span>
<button onclick="memClear()">MC</button>
<button onclick="memRecall()">MR</button>
<button onclick="memAdd()">M+</button>
<button onclick="memSub()">M-</button>
</div>

<div class="display">
<input type="text" id="result" readonly value="0">
</div>

<div class="buttons">
<!-- 1 ряд -->
<button class="func" onclick="add('pi')">π</button>
<button class="func" onclick="add('e')">e</button>
<button class="func" onclick="add('sin(')">sin</button>
<button class="func" onclick="add('cos(')">cos</button>
<button class="func" onclick="add('tan(')">tan</button>
<button class="clear" onclick="clearAll()">C</button>

<!-- 2 ряд -->
<button class="func" onclick="add('asin(')">asin</button>
<button class="func" onclick="add('acos(')">acos</button>
<button class="func" onclick="add('atan(')">atan</button>
<button class="func" onclick="add('ln(')">ln</button>
<button class="func" onclick="add('log(')">log</button>
<button class="clear" onclick="backspace()">⌫</button>

<!-- 3 ряд -->
<button class="func" onclick="add('sqrt(')">√</button>
<button class="func" onclick="add('^')">x^y</button>
<button class="func" onclick="add('abs(')">|x|</button>
<button class="func" onclick="add('1/')">1/x</button>
<button class="op" onclick="add('(')">(</button>
<button class="op" onclick="add(')')">)</button>

<!-- 4 ряд -->
<button class="num" onclick="add('7')">7</button>
<button class="num" onclick="add('8')">8</button>
<button class="num" onclick="add('9')">9</button>
<button class="op" onclick="add('/')">/</button>
<button class="op" onclick="add('*')">*</button>
<button class="op" onclick="add('-')">-</button>

<!-- 5 ряд -->
<button class="num" onclick="add('4')">4</button>
<button class="num" onclick="add('5')">5</button>
<button class="num" onclick="add('6')">6</button>
<button class="op" onclick="add('+')">+</button>
<button class="equals" colspan="2" onclick="calculate()">=</button>

<!-- 6 ряд -->
<button class="num" onclick="add('1')">1</button>
<button class="num" onclick="add('2')">2</button>
<button class="num" onclick="add('3')">3</button>
<button class="num" onclick="add('0')">0</button>
<button class="num" onclick="add('.')">.</button>
</div>

<div style="margin-top:15px; font-size:12px; text-align:center">
<hr>
<b>Как считать:</b><br>
sin(30*pi/180) = 0.5 - синус 30°<br>
2^3 = 8 - два в третьей степени<br>
sqrt(144) = 12 - корень из 144<br>
ln(10) = 2.3026 - натуральный логарифм<br>
log(100) = 2 - десятичный логарифм
</div>
</div>

<script>
var display = document.getElementById('result');
var memory = 0;

function add(val) {
    if(val == 'pi') {
        display.value += '3.14159';
    } else if(val == 'e') {
        display.value += '2.71828';
    } else if(val == '^') {
        display.value += '^';
    } else {
        display.value += val;
    }
}

function clearAll() {
    display.value = '0';
}

function backspace() {
    if(display.value.length > 1) {
        display.value = display.value.slice(0, -1);
    } else {
        display.value = '0';
    }
}

function calculate() {
    try {
        var expr = display.value;
        
        // Замена символов для eval
        expr = expr.replace(/\^/g, '**');
        expr = expr.replace(/pi/g, 'Math.PI');
        expr = expr.replace(/e/g, 'Math.E');
        expr = expr.replace(/sin/g, 'Math.sin');
        expr = expr.replace(/cos/g, 'Math.cos');
        expr = expr.replace(/tan/g, 'Math.tan');
        expr = expr.replace(/asin/g, 'Math.asin');
        expr = expr.replace(/acos/g, 'Math.acos');
        expr = expr.replace(/atan/g, 'Math.atan');
        expr = expr.replace(/ln/g, 'Math.log');
        expr = expr.replace(/log/g, 'Math.log10');
        expr = expr.replace(/sqrt/g, 'Math.sqrt');
        expr = expr.replace(/abs/g, 'Math.abs');
        
        var result = eval(expr);
        display.value = result;
    } catch(e) {
        display.value = 'Ошибка';
    }
}

function memClear() {
    memory = 0;
    document.getElementById('memDisplay').innerHTML = 'Память: 0';
}

function memRecall() {
    display.value += memory;
}

function memAdd() {
    try {
        var val = parseFloat(display.value);
        memory += val;
        document.getElementById('memDisplay').innerHTML = 'Память: ' + memory;
    } catch(e) {}
}

function memSub() {
    try {
        var val = parseFloat(display.value);
        memory -= val;
        document.getElementById('memDisplay').innerHTML = 'Память: ' + memory;
    } catch(e) {}
}

// Поддержка клавиатуры
document.addEventListener('keydown', function(e) {
    if(e.key >= '0' && e.key <= '9') add(e.key);
    if(e.key == '.') add('.');
    if(e.key == '+') add('+');
    if(e.key == '-') add('-');
    if(e.key == '*') add('*');
    if(e.key == '/') add('/');
    if(e.key == '(') add('(');
    if(e.key == ')') add(')');
    if(e.key == 'Enter') calculate();
    if(e.key == 'Escape') clearAll();
    if(e.key == 'Backspace') backspace();
});
</script>

</body>
</html>