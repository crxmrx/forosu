        sol.style.display = 'none';
        total = total + 9;
    } else {
        res.innerHTML = 'НЕПРАВИЛЬНО. Ответ: 6.28';
        res.style.background = '#f8d7da';
        res.style.display = 'block';
        sol.style.display = 'block';
    }
    document.getElementById('totalScore').innerHTML = 'ИТОГО: ' + total + ' / 100 баллов';
}

function resetAll() {
    total = 0;
    document.getElementById('totalScore').innerHTML = 'ИТОГО: 0 / 100 баллов';
    
    for (var i = 1; i <= 6; i++) {
        var res = document.getElementById('res' + i);
        var sol = document.getElementById('sol' + i);
        var inp = document.getElementById('ans' + i);
        if (res) { res.style.display = 'none'; }
        if (sol) { sol.style.display = 'none'; }
        if (inp) { inp.value = ''; }
    }
    
    for (var j = 21; j <= 26; j++) {
        var res = document.getElementById('res' + j);
        var sol = document.getElementById('sol' + j);
        var inp = document.getElementById('ans' + j);
        if (res) { res.style.display = 'none'; }
        if (sol) { sol.style.display = 'none'; }
        if (inp) { inp.value = ''; }
    }
}

function showAll() {
    for (var i = 1; i <= 6; i++) {
        var sol = document.getElementById('sol' + i);
        if (sol) { sol.style.display = 'block'; }
    }
    for (var j = 21; j <= 26; j++) {
        var sol = document.getElementById('sol' + j);
        if (sol) { sol.style.display = 'block'; }
    }
}
</script>

